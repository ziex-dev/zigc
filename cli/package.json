{
  "name": "@zigc/cli",
  "version": "0.15.2",
  "type": "module",
  "description": "Zig compiler CLI via npm - run `bunx @zigc/cli` or `npx @zigc/cli`",
  "bin": {
    "zig": "bin/zig"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ziex-dev/zigc.git"
  },
  "license": "MIT",
  "preferUnplugged": true,
  "dependencies": {
    "@zigc/lib": "0.15.2"
  },
  "optionalDependencies": {
    "@zigc/darwin-arm64": "0.15.2",
    "@zigc/darwin-x64": "0.15.2",
    "@zigc/linux-x64": "0.15.2",
    "@zigc/linux-arm64": "0.15.2",
    "@zigc/win32-x64": "0.15.2",
    "@zigc/win32-arm64": "0.15.2"
  }
}
